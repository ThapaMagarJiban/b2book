{
  "name": "book-manager-api",
  "version": "1.0.0",
  "description": "Book Manager REST API built with Node.js, Express and SQLite",
  "main": "server.js",
  "scripts": {
    "prestart": "npm run build:docs",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docs": "apidoc -i . -o ../APIDOC",
    "build:docs": "npm run docs",
    "test": "jest --runInBand --forceExit",
    "seed": "node db/seed.js"
  },
  "keywords": [
    "book",
    "manager",
    "api",
    "nodejs",
    "express",
    "sqlite"
  ],
  "author": "Book Manager",
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "apidoc": "^1.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "overrides": {
    "bootstrap": "^5.3.8",
    "esbuild": "^0.25.11"
  }
}
